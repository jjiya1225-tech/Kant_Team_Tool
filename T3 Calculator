<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>T3 설치 계산기</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@300;400;500;600;700&display=swap');

  * { margin: 0; padding: 0; box-sizing: border-box; }

  .t3calc-wrap {
    font-family: 'Noto Sans KR', sans-serif;
    max-width: 720px;
    margin: 0 auto;
    padding: 48px 24px;
    color: #222;
    background: #fff;
  }

  .t3calc-wrap h1 {
    font-size: 28px;
    font-weight: 700;
    text-align: center;
    margin-bottom: 8px;
    letter-spacing: -0.5px;
  }

  .t3calc-wrap .subtitle {
    text-align: center;
    color: #888;
    font-size: 14px;
    margin-bottom: 40px;
  }

  /* 형상 선택 */
  .t3calc-section-label {
    font-size: 15px;
    font-weight: 600;
    text-align: center;
    margin-bottom: 14px;
    color: #333;
  }

  .t3calc-shape-btns {
    display: flex;
    justify-content: center;
    gap: 10px;
    margin-bottom: 32px;
  }

  .t3calc-shape-btn {
    padding: 10px 28px;
    border: 2px solid #ddd;
    border-radius: 24px;
    background: #fff;
    font-size: 15px;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s;
    font-family: 'Noto Sans KR', sans-serif;
    color: #555;
  }

  .t3calc-shape-btn:hover {
    border-color: #aaa;
  }

  .t3calc-shape-btn.active {
    background: #222;
    color: #fff;
    border-color: #222;
  }

  /* 길이 입력 */
  .t3calc-inputs {
    display: flex;
    flex-direction: column;
    gap: 16px;
    align-items: center;
    margin-bottom: 12px;
  }

  .t3calc-input-row {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .t3calc-input-row label {
    font-size: 15px;
    font-weight: 500;
    min-width: 90px;
    text-align: right;
    color: #444;
  }

  .t3calc-input-row input {
    width: 160px;
    padding: 10px 14px;
    border: 2px solid #ddd;
    border-radius: 10px;
    font-size: 16px;
    font-family: 'Noto Sans KR', sans-serif;
    text-align: center;
    outline: none;
    transition: border-color 0.2s;
  }

  .t3calc-input-row input:focus {
    border-color: #222;
  }

  .t3calc-input-row .unit {
    font-size: 14px;
    color: #888;
  }

  .t3calc-note {
    text-align: center;
    font-size: 13px;
    color: #999;
    margin-bottom: 28px;
  }

  /* 계산 버튼 */
  .t3calc-btn {
    display: block;
    margin: 0 auto 36px;
    padding: 14px 48px;
    background: #222;
    color: #fff;
    border: none;
    border-radius: 10px;
    font-size: 16px;
    font-weight: 600;
    cursor: pointer;
    font-family: 'Noto Sans KR', sans-serif;
    transition: background 0.2s;
  }

  .t3calc-btn:hover {
    background: #444;
  }

  /* 결과 영역 */
  .t3calc-results {
    display: none;
  }

  .t3calc-results.show {
    display: block;
  }

  .t3calc-divider {
    height: 1px;
    background: #eee;
    margin: 0 0 32px;
  }

  /* 결과 요약 카드 */
  .t3calc-summary {
    background: #f8f8f8;
    border-radius: 14px;
    padding: 24px 28px;
    margin-bottom: 24px;
  }

  .t3calc-summary-title {
    font-size: 17px;
    font-weight: 700;
    margin-bottom: 16px;
    color: #222;
  }

  .t3calc-summary-box {
    background: #fff;
    border: 1px dashed #ccc;
    border-radius: 10px;
    padding: 14px 18px;
    margin-bottom: 14px;
    font-size: 15px;
    font-weight: 500;
    color: #333;
    line-height: 1.6;
  }

  .t3calc-summary-detail {
    font-size: 14px;
    color: #666;
    line-height: 1.8;
  }

  /* 조합 옵션 카드 */
  .t3calc-option-card {
    background: #f8f8f8;
    border-radius: 14px;
    padding: 24px 28px;
    margin-bottom: 16px;
  }

  .t3calc-option-header {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 14px;
  }

  .t3calc-option-title {
    font-size: 16px;
    font-weight: 700;
    color: #222;
  }

  .t3calc-option-badge {
    display: inline-block;
    padding: 3px 10px;
    background: #222;
    color: #fff;
    border-radius: 6px;
    font-size: 12px;
    font-weight: 600;
  }

  .t3calc-option-badge.alt {
    background: #888;
  }

  .t3calc-option-body {
    font-size: 15px;
    line-height: 1.8;
    color: #333;
  }

  .t3calc-option-body .combo-line {
    font-weight: 600;
    margin-bottom: 4px;
  }

  .t3calc-margin-tag {
    display: inline-block;
    padding: 2px 10px;
    background: #e8f5e9;
    color: #2e7d32;
    border-radius: 5px;
    font-size: 13px;
    font-weight: 600;
    margin-right: 6px;
  }

  .t3calc-margin-tag.warn {
    background: #fff3e0;
    color: #e65100;
  }

  .t3calc-detail-text {
    font-size: 13px;
    color: #888;
    margin-top: 4px;
  }

  /* 에러 */
  .t3calc-error {
    text-align: center;
    color: #d32f2f;
    font-size: 14px;
    margin-bottom: 20px;
    display: none;
  }

  .t3calc-error.show {
    display: block;
  }

  /* 반복 구간 (ㄱ자, ㅁ자) */
  .t3calc-side-section {
    margin-bottom: 28px;
  }

  .t3calc-side-label {
    font-size: 16px;
    font-weight: 700;
    color: #222;
    margin-bottom: 16px;
    padding-bottom: 8px;
    border-bottom: 2px solid #eee;
  }

  /* 연결선 안내 */
  .t3calc-connector-info {
    background: #f0f0f0;
    border-radius: 10px;
    padding: 16px 20px;
    margin-bottom: 24px;
    text-align: center;
    font-size: 14px;
    color: #555;
  }

  .t3calc-connector-info strong {
    color: #222;
  }

  @media (max-width: 480px) {
    .t3calc-wrap { padding: 32px 16px; }
    .t3calc-wrap h1 { font-size: 22px; }
    .t3calc-shape-btn { padding: 8px 18px; font-size: 14px; }
    .t3calc-input-row input { width: 120px; }
    .t3calc-summary, .t3calc-option-card { padding: 18px 16px; }
  }
</style>
</head>
<body>

<div class="t3calc-wrap">
  <h1>T3 설치 계산기</h1>
  <p class="subtitle">설치 길이를 입력하면 필요한 T3 조합을 자동으로 계산해 드립니다.</p>

  <!-- 형상 선택 -->
  <p class="t3calc-section-label">설치 형상</p>
  <div class="t3calc-shape-btns">
    <button class="t3calc-shape-btn active" data-shape="line" onclick="t3calc_selectShape('line')">일(ㅡ)자</button>
    <button class="t3calc-shape-btn" data-shape="L" onclick="t3calc_selectShape('L')">ㄱ자</button>
    <button class="t3calc-shape-btn" data-shape="U" onclick="t3calc_selectShape('U')">ㅁ자</button>
  </div>

  <!-- 길이 입력 -->
  <div class="t3calc-inputs" id="t3calc-inputs">
    <div class="t3calc-input-row">
      <label>길이 (mm):</label>
      <input type="number" id="t3calc-len1" min="300" step="1" placeholder="예: 1000">
      <span class="unit">mm</span>
    </div>
  </div>

  <p class="t3calc-note">* 전원 입력선(20mm) 여유가 자동 반영됩니다.<br>* 연결선: 일자 1개 / ㄱ자 2개 / ㅁ자 4개</p>

  <p class="t3calc-error" id="t3calc-error"></p>

  <button class="t3calc-btn" onclick="t3calc_calculate()">조합 계산하기</button>

  <!-- 결과 -->
  <div class="t3calc-results" id="t3calc-results"></div>
</div>

<script>
(function() {
  const SIZES = [1500, 1200, 1000, 900, 600, 400, 300];
  const POWER_CABLE = 20; // mm
  const CONNECTORS = { line: 1, L: 2, U: 4 };

  let currentShape = 'line';

  window.t3calc_selectShape = function(shape) {
    currentShape = shape;
    document.querySelectorAll('.t3calc-shape-btn').forEach(function(btn) {
      btn.classList.toggle('active', btn.getAttribute('data-shape') === shape);
    });
    renderInputs();
    document.getElementById('t3calc-results').innerHTML = '';
    document.getElementById('t3calc-results').classList.remove('show');
    document.getElementById('t3calc-error').classList.remove('show');
  };

  function renderInputs() {
    var container = document.getElementById('t3calc-inputs');
    var html = '';
    if (currentShape === 'line') {
      html = '<div class="t3calc-input-row"><label>길이 (mm):</label><input type="number" id="t3calc-len1" min="300" step="1" placeholder="예: 1000"><span class="unit">mm</span></div>';
    } else if (currentShape === 'L') {
      html = '<div class="t3calc-input-row"><label>가로 (mm):</label><input type="number" id="t3calc-len1" min="300" step="1" placeholder="예: 1000"><span class="unit">mm</span></div>';
      html += '<div class="t3calc-input-row"><label>세로 (mm):</label><input type="number" id="t3calc-len2" min="300" step="1" placeholder="예: 800"><span class="unit">mm</span></div>';
    } else {
      html = '<div class="t3calc-input-row"><label>가로 (mm):</label><input type="number" id="t3calc-len1" min="300" step="1" placeholder="예: 1000"><span class="unit">mm</span></div>';
      html += '<div class="t3calc-input-row"><label>세로 (mm):</label><input type="number" id="t3calc-len2" min="300" step="1" placeholder="예: 800"><span class="unit">mm</span></div>';
    }
    container.innerHTML = html;
  }

  // DP: 주어진 target 이하에서 최적 조합 찾기
  // 우선순위: 1) 여유(margin) 최소화 (최대 커버리지), 2) 개수 최소화
  function findCombinations(inputLength) {
    var target = inputLength - POWER_CABLE;
    if (target < 300) return [];

    // DP in units of 100mm (all sizes are multiples of 100)
    var maxU = Math.floor(target / 100);
    // dp[u] = minimum piece count to make u*100 mm
    var dp = new Array(maxU + 1).fill(Infinity);
    var parent = new Array(maxU + 1).fill(-1);
    dp[0] = 0;

    for (var u = 1; u <= maxU; u++) {
      for (var i = 0; i < SIZES.length; i++) {
        var su = SIZES[i] / 100;
        if (u >= su && dp[u - su] + 1 < dp[u]) {
          dp[u] = dp[u - su] + 1;
          parent[u] = su;
        }
      }
    }

    // Reconstruct pieces for a given unit sum
    function reconstructPieces(u) {
      var pieces = [];
      var rem = u;
      while (rem > 0) {
        pieces.push(parent[rem] * 100);
        rem -= parent[rem];
      }
      pieces.sort(function(a, b) { return b - a; });
      return pieces;
    }

    // Collect best options: for each distinct piece count, keep the highest sum
    // Then rank by margin (ascending) to show closest-to-target first
    var bestByCount = {}; // count -> {u, count, sum, margin, pieces}

    for (var u2 = maxU; u2 >= 3; u2--) {
      if (dp[u2] === Infinity) continue;
      var count = dp[u2];
      // Only keep the highest sum (first encountered from top) per count
      if (!bestByCount[count]) {
        bestByCount[count] = {
          count: count,
          sum: u2 * 100,
          margin: inputLength - u2 * 100,
          pieces: reconstructPieces(u2)
        };
      }
    }

    var options = Object.values(bestByCount);

    // Sort by margin ascending (closest to target first), then count ascending
    options.sort(function(a, b) {
      if (a.margin !== b.margin) return a.margin - b.margin;
      return a.count - b.count;
    });

    // Return top 3
    return options.slice(0, 3);
  }

  function pieceSummary(pieces) {
    var counts = {};
    pieces.forEach(function(p) {
      counts[p] = (counts[p] || 0) + 1;
    });
    var parts = [];
    // Sort desc
    var keys = Object.keys(counts).map(Number).sort(function(a, b) { return b - a; });
    keys.forEach(function(k) {
      parts.push(k + 'mm ' + counts[k] + '개');
    });
    return parts.join(' / ');
  }

  function pieceDetail(pieces) {
    var counts = {};
    pieces.forEach(function(p) {
      counts[p] = (counts[p] || 0) + 1;
    });
    var parts = [];
    var keys = Object.keys(counts).map(Number).sort(function(a, b) { return b - a; });
    keys.forEach(function(k) {
      parts.push('T3 ' + k + ' × ' + counts[k] + '개');
    });
    return parts.join(' + ');
  }

  window.t3calc_calculate = function() {
    var errEl = document.getElementById('t3calc-error');
    var resEl = document.getElementById('t3calc-results');
    errEl.classList.remove('show');
    resEl.classList.remove('show');
    resEl.innerHTML = '';

    var sides = [];
    var labels = [];

    if (currentShape === 'line') {
      var v1 = parseInt(document.getElementById('t3calc-len1').value);
      if (!v1 || v1 < 300) {
        errEl.textContent = '길이를 300mm 이상 입력해주세요.';
        errEl.classList.add('show');
        return;
      }
      sides.push(v1);
      labels.push('');
    } else if (currentShape === 'L') {
      var h = parseInt(document.getElementById('t3calc-len1').value);
      var v = parseInt(document.getElementById('t3calc-len2').value);
      if (!h || h < 300 || !v || v < 300) {
        errEl.textContent = '가로, 세로 모두 300mm 이상 입력해주세요.';
        errEl.classList.add('show');
        return;
      }
      sides.push(h);
      sides.push(v);
      labels.push('가로');
      labels.push('세로');
    } else {
      var h2 = parseInt(document.getElementById('t3calc-len1').value);
      var v2 = parseInt(document.getElementById('t3calc-len2').value);
      if (!h2 || h2 < 300 || !v2 || v2 < 300) {
        errEl.textContent = '가로, 세로 모두 300mm 이상 입력해주세요.';
        errEl.classList.add('show');
        return;
      }
      sides.push(h2);
      sides.push(v2);
      sides.push(h2);
      sides.push(v2);
      labels.push('가로 ①');
      labels.push('세로 ①');
      labels.push('가로 ②');
      labels.push('세로 ②');
    }

    // Calculate each side
    var allSideResults = [];
    var hasError = false;

    sides.forEach(function(len, idx) {
      var combos = findCombinations(len);
      if (combos.length === 0) {
        hasError = true;
      }
      allSideResults.push({ length: len, label: labels[idx], combos: combos });
    });

    if (hasError) {
      errEl.textContent = '조합을 찾을 수 없습니다. 길이를 확인해주세요. (최소 320mm 이상)';
      errEl.classList.add('show');
      return;
    }

    var connectorCount = CONNECTORS[currentShape];
    var html = '';

    // === 결과 요약 (최적 조합 기준) ===
    var totalPieces = 0;
    var totalSum = 0;
    var summaryParts = [];

    allSideResults.forEach(function(sr) {
      var best = sr.combos[0];
      totalPieces += best.count;
      totalSum += best.sum;
      if (sr.label) {
        summaryParts.push('<strong>' + sr.label + ':</strong> ' + pieceSummary(best.pieces));
      } else {
        summaryParts.push(pieceSummary(best.pieces));
      }
    });

    html += '<div class="t3calc-divider"></div>';

    // 연결선 안내
    html += '<div class="t3calc-connector-info">연결선 <strong>' + connectorCount + '개</strong> 필요 (' + (currentShape === 'line' ? '일자' : currentShape === 'L' ? 'ㄱ자' : 'ㅁ자') + ' 형상)</div>';

    // 결과 요약
    html += '<div class="t3calc-summary">';
    html += '<div class="t3calc-summary-title">T3 결과 요약 (추천)</div>';
    html += '<div class="t3calc-summary-box">구성: ' + summaryParts.join('<br>') + '<br>+연결선 ' + connectorCount + '개</div>';
    html += '<div class="t3calc-summary-detail">';
    html += '전등 총 길이: ' + totalSum + 'mm<br>';
    html += '전등 총 개수: ' + totalPieces + '개';
    html += '</div>';
    html += '</div>';

    // === 각 면별 상세 조합 ===
    allSideResults.forEach(function(sr, sIdx) {
      if (labels[0] !== '') {
        html += '<div class="t3calc-side-section">';
        html += '<div class="t3calc-side-label">' + sr.label + ' — 길이 ' + sr.length + 'mm</div>';
      }

      sr.combos.forEach(function(opt, oIdx) {
        html += '<div class="t3calc-option-card">';
        html += '<div class="t3calc-option-header">';

        if (labels[0] === '') {
          html += '<span class="t3calc-option-title">T3 조합 ' + (oIdx + 1) + '</span>';
        } else {
          html += '<span class="t3calc-option-title">조합 ' + (oIdx + 1) + '</span>';
        }

        if (oIdx === 0) {
          html += '<span class="t3calc-option-badge">추천</span>';
        } else {
          html += '<span class="t3calc-option-badge alt">대안</span>';
        }

        html += '<span style="font-size:13px;color:#888;">전등 ' + opt.count + '개</span>';
        html += '</div>';

        html += '<div class="t3calc-option-body">';
        html += '<div class="combo-line">' + pieceDetail(opt.pieces) + '</div>';

        var marginClass = opt.margin >= 20 ? '' : ' warn';
        html += '<span class="t3calc-margin-tag' + marginClass + '">여유 ' + opt.margin + 'mm</span>';
        html += '<span class="t3calc-detail-text">전등 합계: ' + opt.sum + 'mm</span>';
        html += '</div>';
        html += '</div>';
      });

      if (labels[0] !== '') {
        html += '</div>';
      }
    });

    resEl.innerHTML = html;
    resEl.classList.add('show');
  };
})();
</script>

</body>
</html>
